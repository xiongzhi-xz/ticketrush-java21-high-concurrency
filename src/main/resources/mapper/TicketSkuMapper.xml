<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ticketrush.infrastructure.mysql.mapper.TicketSkuMapper">

    <resultMap id="TicketSkuResultMap" type="com.ticketrush.domain.model.TicketSku">
        <constructor>
            <idArg column="id" javaType="java.lang.Long"/>
            <arg column="event_id" javaType="java.lang.Long"/>
            <arg column="name" javaType="java.lang.String"/>
            <arg column="price_fen" javaType="java.lang.Long"/>
            <arg column="total_stock" javaType="java.lang.Integer"/>
            <arg column="sale_start_time" javaType="java.time.LocalDateTime"/>
            <arg column="sale_end_time" javaType="java.time.LocalDateTime"/>
            <arg column="status" javaType="com.ticketrush.domain.model.SkuStatus"/>
            <arg column="created_at" javaType="java.time.LocalDateTime"/>
            <arg column="updated_at" javaType="java.time.LocalDateTime"/>
        </constructor>
    </resultMap>

    <sql id="TicketSkuColumns">
        id,
        event_id,
        name,
        price_fen,
        total_stock,
        sale_start_time,
        sale_end_time,
        status,
        created_at,
        updated_at
    </sql>

    <select id="findById" resultMap="TicketSkuResultMap">
        SELECT
        <include refid="TicketSkuColumns"/>
        FROM ticket_sku
        WHERE id = #{id}
    </select>

    <select id="findByEventId" resultMap="TicketSkuResultMap">
        SELECT
        <include refid="TicketSkuColumns"/>
        FROM ticket_sku
        WHERE event_id = #{eventId}
        ORDER BY id ASC
    </select>

    <insert id="insert" parameterType="com.ticketrush.domain.model.TicketSku">
        INSERT INTO ticket_sku
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="id != null">id,</if>
            event_id,
            name,
            price_fen,
            total_stock,
            sale_start_time,
            sale_end_time,
            status,
            <if test="createdAt != null">created_at,</if>
            <if test="updatedAt != null">updated_at,</if>
        </trim>
        <trim prefix="VALUES (" suffix=")" suffixOverrides=",">
            <if test="id != null">#{id},</if>
            #{eventId},
            #{name},
            #{priceFen},
            #{totalStock},
            #{saleStartTime},
            #{saleEndTime},
            #{status},
            <if test="createdAt != null">#{createdAt},</if>
            <if test="updatedAt != null">#{updatedAt},</if>
        </trim>
    </insert>

    <update id="updateStatus">
        UPDATE ticket_sku
        SET status = #{status},
            updated_at = CURRENT_TIMESTAMP(3)
        WHERE id = #{id}
    </update>
</mapper>
